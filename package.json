{
  "name": "moba-magic-atoms",
  "productName": "MOBA — Magic Orbiting Brandished Atoms",
  "version": "0.1.0",
  "description": "MOBA (Magic Orbiting Brandished Atoms) — 3v3 fork from IDLE-CRAFT world tech (EmpireEngine)",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "prepare": "node scripts/download-default-music.mjs && node scripts/compress-hero-backgrounds.mjs",
    "dev": "node scripts/compress-hero-backgrounds.mjs && vite",
    "rooms": "npm --prefix server start",
    "compress:images": "node scripts/compress-hero-backgrounds.mjs",
    "build": "node scripts/compress-hero-backgrounds.mjs && tsc && vite build",
    "deploy:netlify": "npm run build && netlify deploy --dir=dist --prod",
    "deploy:fly": "cd server && fly deploy",
    "preview": "vite preview",
    "electron": "npm run build && electron .",
    "build:icons": "node scripts/build-icon.cjs",
    "package": "npm run build && npm run build:icons && node scripts/stage-squirrel-icon.cjs && electron-forge package",
    "make": "npm run build && npm run build:icons && node scripts/stage-squirrel-icon.cjs && electron-forge make"
  },
  "config": {
    "forge": "./forge.config.cjs"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "empire-engine": "file:../EmpireEngine",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@types/three": "^0.182.0",
    "electron": "^39.2.0",
    "png-to-ico": "^2.1.8",
    "rcedit": "^4.0.1",
    "sharp": "^0.33.5",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.21.2"
  }
}
